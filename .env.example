# =============================================================================
# QuantGuild — Environment Variables
# Copy this file to .env and fill in all required values before starting.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Set to True only for local development (enables auto-reload, debug routes, etc.)
DEBUG=False

# -----------------------------------------------------------------------------
# Database (PostgreSQL / TimescaleDB)
# -----------------------------------------------------------------------------
POSTGRES_USER=quantguild
POSTGRES_PASSWORD=
POSTGRES_DB=quantguild

# Constructed automatically by docker-compose from the above values.
# Override manually if connecting to an external database:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=

# Constructed automatically by docker-compose.
# Override manually if using an external Redis:
# REDIS_URL=redis://:password@host:6379/0

# -----------------------------------------------------------------------------
# Celery (uses Redis — constructed from REDIS_PASSWORD by docker-compose)
# Override manually if needed:
# CELERY_BROKER_URL=redis://:password@host:6379/1
# CELERY_RESULT_BACKEND=redis://:password@host:6379/2
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# CORS — space- or comma-separated list of allowed origins
# Pydantic parses JSON arrays: CORS_ORIGINS=["https://example.com"]
# -----------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000"]

# Public URL for links in emails (password reset, email verify)
FRONTEND_URL=http://localhost:3000

# Frontend environment (set to your public domain in production)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# -----------------------------------------------------------------------------
# Email (SMTP) — leave SMTP_HOST empty to disable email sending
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@quantguild.com
SMTP_TLS=True

# -----------------------------------------------------------------------------
# TOTP 2FA — 32-byte base64 Fernet key
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to derive from SECRET_KEY (weaker; not recommended for production)
# -----------------------------------------------------------------------------
TOTP_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Strategy encryption at rest — encrypts strategy code/description in DB
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to derive from SECRET_KEY. Set explicitly in production for stronger security.
# -----------------------------------------------------------------------------
STRATEGY_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# S3 / MinIO
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Constructed automatically by docker-compose.
# Override for external S3:
# S3_ENDPOINT=s3.amazonaws.com
# S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET_NAME=ceapcouncil
S3_USE_SSL=True
# Public URL prefix for user-uploaded media (avatars etc.)
# In production: https://ceapcouncil.com/media
# In dev with direct MinIO: http://localhost:9000/ceapcouncil
MEDIA_BASE_URL=https://ceapcouncil.com/media
